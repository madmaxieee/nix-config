{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "google": { "options": { "apiKey": "{env:GEMINI_API_KEY}" } },
  },
  "experimental": { "openTelemetry": false },
  "agent": {
    "build": {
      "model": "google/gemini-3-flash-preview",
      "variant": "low",
      "color": "secondary",
    },
    "plan": {
      "model": "google/gemini-3-flash-preview",
      "variant": "high",
      "color": "accent",
    },
    "fast": {
      "mode": "subagent",
      "model": "google/gemini-3.1-flash-lite-preview",
      "color": "success",
    },
  },
  "mcp": {
    "fff": {
      "type": "local",
      "command": ["fff-mcp"],
      "enabled": true,
    },
  },
}
