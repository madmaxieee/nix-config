{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "opencode-go/glm-5.1",
      "color": "secondary",
      "mode": "all",
    },
    "plan": {
      "model": "opencode-go/qwen3.6-plus",
      "color": "accent",
    },
    "general": {
      "model": "opencode-go/glm-5.1",
    },
    "fast": {
      "mode": "subagent",
      "model": "opencode-go/qwen3.5-plus",
      "color": "success",
    },
  },
  "mcp": {
    "fff": {
      "type": "local",
      "command": ["fff-mcp"],
      "enabled": true,
    },
  },
  "experimental": { "openTelemetry": false },
  "share": "disabled",
}
