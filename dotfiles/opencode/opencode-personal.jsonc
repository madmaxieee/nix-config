{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "opencode-go/glm-5.1",
      "color": "secondary",
    },
    "plan": {
      "model": "opencode-go/kimi-k2.5",
      "color": "accent",
    },
    "fast": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "color": "success",
    },
  },
  "mcp": {
    "fff": {
      "type": "local",
      "command": ["fff-mcp"],
      "enabled": true,
    },
  },
  "experimental": { "openTelemetry": false },
  "share": "disabled",
}
