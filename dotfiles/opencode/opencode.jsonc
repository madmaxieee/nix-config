{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}",
      },
    },
  },
  "model": "google/gemini-3.1-pro-preview",
  "mcp": {
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true,
    },
  },
}
